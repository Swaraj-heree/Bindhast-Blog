<%- include("partials/header") %>
<% if(titles.length===0) { %>
    <p>No posts available.</p>
<% } else { %>
    <h1>All Posts</h1>
<% posts.forEach(post => { %>

<div class="card my-3">
    <div class="card-body">
        <h2><%= post.title %></h2>
        <p><%= post.content %></p>
    </div>
</div>

<% }) %>
<% } %>

<%- include("partials/footer") %>